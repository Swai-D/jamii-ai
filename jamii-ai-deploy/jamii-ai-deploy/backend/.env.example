# ══════════════════════════════════════════════════════
#  JamiiAI Backend — Railway Environment Variables
#  Copy these into Railway → Variables tab
# ══════════════════════════════════════════════════════

# Auto-set by Railway when you add PostgreSQL plugin:
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PASTE_YOUR_64_CHAR_SECRET_HERE

# Your Vercel frontend URL
CLIENT_URL=https://jamii-ai.vercel.app

NODE_ENV=production
PORT=4000
