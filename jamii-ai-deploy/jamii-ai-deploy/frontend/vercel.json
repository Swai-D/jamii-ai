{
  "version": 2,
  "name": "jamii-ai-frontend",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://jamii-ai-backend.up.railway.app/api/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://jamii-ai-backend.up.railway.app"
  }
}
